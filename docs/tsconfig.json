{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "allowUnusedLabels": true,
    "checkJs": true,
    "esModuleInterop": true,
    "explainFiles": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "module": "esnext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noEmitOnError": false,
    "noErrorTruncation": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "@reduxjs/toolkit": ["../packages/toolkit/dist/index.d.ts"],
      "@reduxjs/toolkit/query": ["../packages/toolkit/dist/query/index.d.ts"],
      "@reduxjs/toolkit/query/react": [
        "../packages/toolkit/dist/query/react/index.d.ts"
      ],
      "@virtual/matchers": ["./virtual/matchers/index.ts"],
      "your-cool-library": ["./virtual/your-cool-library/index.ts"],
      "redux-logger": ["./virtual/redux-logger/index.ts"],
      "petstore-api.generated": ["./virtual/petstore-api.generated/index.ts"]
    },
    "removeComments": false,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "traceResolution": false,
    "types": [],
    "useDefineForClassFields": true,
    "useUnknownInCatchVariables": true,
    "verbatimModuleSyntax": true
  }
}
