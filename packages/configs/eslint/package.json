{
  "name": "@reduxjs/eslint-config",
  "version": "0.0.1",
  "description": "ESLint configuration for Redux projects",
  "types": "./dist/eslint.config.d.mts",
  "main": "./dist/eslint.config.mjs",
  "module": "./dist/eslint.config.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/eslint.config.d.mts",
      "import": "./dist/eslint.config.mjs",
      "default": "./dist/eslint.config.mjs"
    }
  },
  "files": [
    "dist",
    "*.mts"
  ],
  "scripts": {
    "build": "yarn clean && tsc",
    "clean": "rimraf dist",
    "prepack": "yarn build"
  },
  "keywords": [
    "eslint",
    "config",
    "eslint-config",
    "reduxjs",
    "redux-toolkit",
    "configuration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/reduxjs/redux-toolkit.git",
    "directory": "packages/configs/eslint"
  },
  "bugs": {
    "url": "https://github.com/reduxjs/redux-toolkit/issues"
  },
  "peerDependencies": {
    "eslint": "^8.56.0 || ^9",
    "prettier": "^3",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@reduxjs/tsconfig": "workspace:^",
    "@types/eslint": "^8.56.10",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__eslintrc": "^2.1.1",
    "@types/eslint__js": "^8.42.3",
    "eslint": "^9.6.0",
    "eslint-plugin-prettier": "^5.1.3",
    "rimraf": "^5.0.7",
    "tslib": "^2.6.3",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@eslint/js": "^9.6.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.6.0",
    "typescript-eslint": "^7.14.1"
  }
}
