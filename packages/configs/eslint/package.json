{
  "name": "@reduxjs/eslint-config",
  "version": "0.0.1",
  "description": "ESLint configuration for Redux projects",
  "types": "./dist/eslint.config.d.mts",
  "main": "./dist/eslint.config.mjs",
  "module": "./dist/eslint.config.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/eslint.config.d.mts",
        "default": "./dist/eslint.config.mjs"
      },
      "node": {
        "types": "./dist/eslint.config.d.mts",
        "default": "./dist/eslint.config.mjs"
      }
    }
  },
  "files": [
    "dist",
    "*.mts"
  ],
  "scripts": {
    "build": "yarn clean && tsc",
    "clean": "rimraf dist",
    "prepack": "yarn build"
  },
  "keywords": [
    "eslint",
    "config",
    "eslint-config",
    "reduxjs",
    "redux-toolkit",
    "configuration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@eslint/js": "^8.57.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@typescript-eslint/utils": "^7.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tslib": "2.6.2",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reduxjs/redux-toolkit.git"
  },
  "devDependencies": {
    "@reduxjs/tsconfig": "workspace:^",
    "@types/eslint": "^8.56.5",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint__eslintrc": "^2.1.1",
    "@types/eslint__js": "^8.42.3",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@eslint/js": "^8.57.0",
    "@typescript-eslint/utils": "^7.2.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^14.0.0",
    "tslib": "2.6.2",
    "typescript-eslint": "^7.2.0"
  }
}
