    "url": "git+https://github.com/reduxjs/redux-toolkit.git"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
