{
  "name": "@reduxjs/eslint-config",
  "version": "0.0.1",
  "description": "ESLint configuration for Redux projects",
  "main": "./dist/eslint.config.js",
  "types": "./dist/eslint.config.d.ts",
  "scripts": {
    "build": "yarn clean && tsc",
    "clean": "rimraf dist"
  },
  "keywords": [
    "eslint",
    "config",
    "eslint-config",
    "reduxjs",
    "redux-toolkit",
