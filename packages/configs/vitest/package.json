{
  "name": "@reduxjs/vitest-config",
  "version": "0.0.1",
  "description": "Vitest configuration for Redux projects",
  "main": "./dist/vitest.config.mjs",
  "types": "./dist/vitest.config.d.mts",
  "module": "./dist/vitest.config.mjs",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/vitest.config.d.mts",
        "default": "./dist/vitest.config.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn clean && tsc",
    "clean": "rimraf dist",
    "prepack": "yarn build"
  },
  "keywords": [
    "config",
    "reduxjs",
    "redux-toolkit",
    "vitest-config",
    "vitest",
    "vite",
    "configuration"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reduxjs/redux-toolkit.git"
  },
  "devDependencies": {
    "@reduxjs/tsconfig": "workspace:^",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.3.1"
  }
}
