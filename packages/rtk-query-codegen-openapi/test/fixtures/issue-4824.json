{
  "openapi": "3.0.0",
  "info": {
    "title": "Issue 4824 - optional request body",
    "version": "1.0.0"
  },
  "paths": {
    "/foo": {
      "delete": {
        "operationId": "deleteFoo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/bar": {
      "post": {
        "operationId": "createBar",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}
