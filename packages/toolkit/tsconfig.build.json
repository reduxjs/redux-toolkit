{
  // For building the library.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts*",
    "src/**/*.test-d.ts*",
    "src/**/*.spec.ts*",
    "src/**/tests/*",
    "src/**/*.typetest.ts*"
  ]
}
