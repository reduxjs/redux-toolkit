{
  // For building the library.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts*",
    "src/**/*.test-d.ts*",
    "src/**/*.spec.ts*",
    "src/**/tests/*",
    "src/**/*.typetest.ts*"
  ]
}
